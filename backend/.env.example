# AWS — IAM Identity Center (SSO) recommended
# 1. Run: aws configure sso
#    SSO start URL: https://slalom-hackathon.awsapps.com/start/#
#    SSO region: eu-central-1
# 2. Set AWS_PROFILE to the profile name you chose
# 3. Before starting the backend, run: aws sso login
AWS_PROFILE=slalom-hackathon
AWS_REGION=us-east-1

# Or use long-lived IAM user keys (not recommended for team/hackathon):
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_REGION=us-east-1

# Toggle-to-mock: set to true to use real Bedrock for that feature (or DEMO_GLOBAL=true for all)
DEMO_GLOBAL=false
DEMO_INGEST=true
DEMO_MARKET=true
DEMO_VC_SCOUT=false
DEMO_ASSET_FORGE=false
DEMO_CODE_LAB=false
DEMO_FINANCE=false
# Virtual Tank + full speech-to-speech (Nova Sonic). Requires aws_sdk_bedrock_runtime (Python 3.12+).
DEMO_TANK=false

# When false, disables Nova web grounding (avoids AccessDeniedException if org SCP denies bedrock:InvokeTool)
# ALLOW_WEB_GROUNDING=false

# When true (default), use custom web_search tool for Market Intel research when ALLOW_WEB_GROUNDING is false.
# Nova then invokes our tool; we run DuckDuckGo (no key) or SerpAPI (set SERPAPI_API_KEY for Google results).
# USE_CUSTOM_WEB_SEARCH=true
# SERPAPI_API_KEY=optional_key_for_serpapi

# PostgreSQL (optional). Start DB with: docker compose up -d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flightdeck

# Production: allow frontend origin(s) for CORS (comma-separated, no spaces). Required so judges can use the deployed app.
# CORS_ORIGINS=https://your-app.vercel.app

# S3 bucket for Nova Reel pitch video output (optional).
# S3_BUCKET=your-bucket-name
